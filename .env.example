# Copy to .env (gitignored) and fill in. Loaded by docker-compose (env_file:) and
# usable for local runs: `set -a; . ./.env; set +a`.
# This lists every env var obagent + the scripts read.

# --- Secrets (required) ---
NOTION_TOKEN=ntn_xxx
MISTRAL_API_KEY=xxx
OPENAI_API_KEY=xxx

# --- Notion data sources (required for `obagent notion sync`; no defaults) ---
# A type whose id is unset is simply not synced.
OBAGENT_NOTION_RECEIPT_DS=
OBAGENT_NOTION_DOCUMENT_DS=

# --- Paths (required) ---
# In Docker these are set by docker-compose.yml (container paths) and take
# precedence; uncomment here for local / non-container runs.
# OBAGENT_VAULT=/path/to/vault           # dir containing Receipts/, Documents/, ...
# OBAGENT_CONSUME=/path/to/inbox         # scanner drop root (per-type subdirs)
# OBAGENT_EXPORT=/path/to/drive-export   # Cloud Sync -> Google Drive

# --- Optional (defaults shown) ---
# OBAGENT_MIN_AGE=60                      # consume: skip scans modified within N seconds
# OBAGENT_INTERVAL=300                    # loop.sh: seconds between passes
# OBAGENT_GIT_REMOTES="github gitlab"    # publish.sh: default = all configured remotes
# OBAGENT_LOCK=/path/to/run.lock         # run.sh lock (default: $OBAGENT_VAULT/.obagent/run.lock)
# OBAGENT_CONSUME_PREHOOK='rclone copy gdrive:scans $OBAGENT_CONSUME'  # before consume
