# Copy to .env (gitignored) and fill in.
# Used by docker-compose (env_file) and by local runs: `set -a; . ./.env; set +a`.

NOTION_TOKEN=ntn_xxx
MISTRAL_API_KEY=xxx
OPENAI_API_KEY=xxx

# Notion data source ids — required for `obagent notion sync` (no defaults; these
# are workspace-specific). A type whose id is unset is simply not synced.
OBAGENT_NOTION_RECEIPT_DS=
OBAGENT_NOTION_DOCUMENT_DS=
